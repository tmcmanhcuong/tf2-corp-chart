{
  "$schema": "http://json-schema.org/schema#",
  "type": "object",
  "title": "Values",
  "additionalProperties": false,
  "properties": {
    "enabled": {
      "description": "Usually used when using Opentelemetry-demo as a subchart.",
      "type": "boolean"
    },
    "global": {
      "type": "object"
    },
    "default": {
      "$ref": "#/definitions/Default"
    },
    "mem0": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "awsRegion": {
          "type": "string"
        },
        "replicas": {
          "type": "integer",
          "minimum": 0
        },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "repository": {
              "type": "string"
            },
            "tag": {
              "type": "string"
            },
            "digest": {
              "type": "string",
              "description": "Immutable mem0 image digest pin from service-digest promote.",
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          }
        },
        "rds": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "host": {
              "type": "string"
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "database": {
              "type": "string"
            },
            "appUser": {
              "type": "string"
            }
          }
        },
        "serviceAccount": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "roleArn": {
              "type": "string"
            }
          }
        },
        "runtimeSecretName": {
          "type": "string"
        },
        "masterSecretName": {
          "type": "string"
        },
        "cleanupSchedule": {
          "type": "string"
        },
        "resources": {
          "type": "object"
        },
        "migrate": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ttlSecondsAfterFinished": {
              "type": "integer",
              "minimum": 0
            },
            "resources": {
              "type": "object"
            }
          }
        },
        "cleanup": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "resources": {
              "type": "object"
            }
          }
        },
        "probes": {
          "type": "object"
        },
        "modelDelivery": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "awsRegion": {
              "type": "string"
            },
            "fetcherImage": {
              "type": "string"
            },
            "extractorImage": {
              "type": "string"
            },
            "s3Prefix": {
              "type": "string",
              "description": "S3 prefix for FastEmbed artifacts; URI is s3Prefix/imageTag/archiveName"
            },
            "archiveName": {
              "type": "string",
              "description": "Immutable FastEmbed archive filename under the image tag prefix"
            },
            "s3Uri": {
              "type": "string",
              "description": "Optional full object URI override; when set, skips s3Prefix composition"
            },
            "mountPath": {
              "type": "string"
            },
            "cacheSizeLimit": {
              "type": "string"
            },
            "resources": {
              "type": "object"
            }
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean"
        },
        "annotations": {
          "type": "object"
        },
        "name": {
          "type": "string"
        },
        "automountServiceAccountToken": {
          "type": "boolean",
          "const": false
        }
      },
      "required": [
        "create"
      ]
    },
    "components": {
      "$ref": "#/definitions/Components"
    },
    "opentelemetry-collector": {
      "type": "object"
    },
    "jaeger": {
      "type": "object"
    },
    "prometheus": {
      "type": "object"
    },
    "grafana": {
      "type": "object"
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "enforceEgress": {
          "type": "boolean"
        },
        "vpcCidr": {
          "type": "string"
        },
        "kubernetesApiCidr": {
          "type": "string",
          "pattern": "^(?:[0-9]{1,3}\\.){3}[0-9]{1,3}/32$"
        },
        "albIngressCidrs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "flagdSyncCidrs": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": [
        "enabled",
        "enforceEgress",
        "vpcCidr",
        "kubernetesApiCidr",
        "albIngressCidrs",
        "flagdSyncCidrs"
      ]
    },
    "egressProxy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "replicas": { "type": "integer", "minimum": 2 },
        "image": { "$ref": "#/definitions/Image" },
        "port": { "type": "integer", "minimum": 1024, "maximum": 65535 },
        "adminPort": { "type": "integer", "minimum": 1024, "maximum": 65535 },
        "callers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "noProxy": { "type": "string" },
        "allowedDomains": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "resources": { "type": "object" }
      },
      "required": [
        "enabled", "replicas", "image", "port", "adminPort", "callers",
        "noProxy", "allowedDomains", "resources"
      ]
    },
    "externalSecrets": {
      "type": "object",
      "description": "SEC-05 documentation block; ExternalSecrets live in secrets-chart release",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "When true, app chart expects ESO-synced Secrets (default production path)"
        },
        "secretStoreName": {
          "type": "string"
        },
        "namespace": {
          "type": "string"
        }
      }
    },
    "runtimeHardeningInventory": {
      "type": "object",
      "description": "Mandate 05 scheduled runtime-hardening drift scanner",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "clusterName": {
          "type": "string"
        },
        "environment": {
          "type": "string"
        },
        "schedule": {
          "type": "string"
        },
        "successfulJobsHistoryLimit": {
          "type": "integer",
          "minimum": 0
        },
        "failedJobsHistoryLimit": {
          "type": "integer",
          "minimum": 0
        },
        "activeDeadlineSeconds": {
          "type": "integer",
          "minimum": 30
        },
        "backoffLimit": {
          "type": "integer",
          "minimum": 0
        },
        "serviceAccountName": {
          "type": "string"
        },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "repository": {
              "type": "string"
            },
            "tag": {
              "type": "string",
              "minLength": 1
            },
            "pullPolicy": {
              "type": "string"
            }
          },
          "required": [
            "repository",
            "tag"
          ]
        },
        "resources": {
          "$ref": "#/definitions/ContainerResources"
        },
        "securityContext": {
          "$ref": "#/definitions/SecurityContext"
        },
        "podSecurityContext": {
          "$ref": "#/definitions/PodSecurityContext"
        },
        "exceptionProfiles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "rootKey": {
                "type": "string"
              },
              "containers": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "rules": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "NON_ROOT",
                    "UID_0",
                    "DROP_ALL",
                    "ADDED_CAPS",
                    "PRIVILEGED",
                    "PRIV_ESC",
                    "HOST_NETWORK",
                    "HOST_PID",
                    "HOST_IPC",
                    "HOST_PATH",
                    "IMAGE_PIN",
                    "RESOURCES"
                  ]
                }
              }
            },
            "required": [
              "rootKey",
              "containers",
              "rules"
            ]
          }
        }
      },
      "required": [
        "enabled",
        "schedule",
        "image",
        "resources",
        "securityContext",
        "podSecurityContext"
      ]
    },
    "metrics-server": {
      "type": "object",
      "description": "Kubernetes Metrics Server (required for HPA CPU/memory metrics)"
    },
    "prometheus-adapter": {
      "type": "object",
      "description": "Prometheus Adapter (external metrics for request-rate HPA)"
    }
  },
  "required": [
    "components",
    "serviceAccount"
  ],
  "allOf": [
    {
      "if": {
        "required": ["networkPolicy"],
        "properties": {
          "networkPolicy": {
            "required": ["enforceEgress"],
            "properties": {
              "enforceEgress": { "const": true }
            }
          }
        }
      },
      "then": {
        "properties": {
          "networkPolicy": {
            "required": ["enabled"],
            "properties": {
              "enabled": { "const": true }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["networkPolicy"],
        "properties": {
          "networkPolicy": {
            "required": ["enforceEgress"],
            "properties": {
              "enforceEgress": { "const": true }
            }
          }
        }
      },
      "then": {
        "required": ["egressProxy"],
        "properties": {
          "egressProxy": {
            "required": ["enabled"],
            "properties": {
              "enabled": { "const": true }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["networkPolicy"],
        "properties": {
          "networkPolicy": {
            "required": ["enforceEgress"],
            "properties": {
              "enforceEgress": { "const": true }
            }
          }
        }
      },
      "then": {
        "required": ["egressProxy"],
        "properties": {
          "egressProxy": {
            "required": ["image"],
            "properties": {
              "image": {
                "required": ["digest"],
                "properties": {
                  "digest": { "pattern": "^sha256:[0-9a-f]{64}$" }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["networkPolicy"],
        "properties": {
          "networkPolicy": {
            "required": ["enforceEgress"],
            "properties": {
              "enforceEgress": { "const": true }
            }
          }
        }
      },
      "then": {
        "required": ["egressProxy", "grafana"],
        "properties": {
          "egressProxy": {
            "required": ["callers", "allowedDomains"],
            "properties": {
              "callers": { "contains": { "const": "grafana" } },
              "allowedDomains": {
                "allOf": [
                  { "contains": { "const": "athena.ap-southeast-1.amazonaws.com:443" } },
                  { "contains": { "const": "glue.ap-southeast-1.amazonaws.com:443" } },
                  { "contains": { "const": "sts.ap-southeast-1.amazonaws.com:443" } },
                  { "contains": { "const": "s3.ap-southeast-1.amazonaws.com:443" } },
                  { "contains": { "const": "*.s3.ap-southeast-1.amazonaws.com:443" } },
                  { "contains": { "const": "discord.com:443" } }
                ]
              }
            }
          },
          "grafana": {
            "required": ["env"],
            "properties": {
              "env": {
                "type": "object",
                "required": ["HTTPS_PROXY", "https_proxy", "NO_PROXY", "no_proxy"],
                "properties": {
                  "HTTPS_PROXY": { "const": "http://egress-proxy:10000" },
                  "https_proxy": { "const": "http://egress-proxy:10000" },
                  "NO_PROXY": { "type": "string", "minLength": 1 },
                  "no_proxy": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "Components": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "accounting": {
          "$ref": "#/definitions/Component"
        },
        "ad": {
          "$ref": "#/definitions/Component"
        },
        "cart": {
          "$ref": "#/definitions/Component"
        },
        "checkout": {
          "$ref": "#/definitions/Component"
        },
        "currency": {
          "$ref": "#/definitions/Component"
        },
        "email": {
          "$ref": "#/definitions/Component"
        },
        "flagd": {
          "$ref": "#/definitions/Component"
        },
        "fraud-detection": {
          "$ref": "#/definitions/Component"
        },
        "frontend": {
          "$ref": "#/definitions/Component"
        },
        "frontend-proxy": {
          "$ref": "#/definitions/Component"
        },
        "image-provider": {
          "$ref": "#/definitions/Component"
        },
        "load-generator": {
          "$ref": "#/definitions/Component"
        },
        "load-generator-worker": {
          "$ref": "#/definitions/Component"
        },
        "payment": {
          "$ref": "#/definitions/Component"
        },
        "product-catalog": {
          "$ref": "#/definitions/Component"
        },
        "product-reviews": {
          "$ref": "#/definitions/Component"
        },
        "shopping-copilot": {
          "$ref": "#/definitions/Component"
        },
        "quote": {
          "$ref": "#/definitions/Component"
        },
        "recommendation": {
          "$ref": "#/definitions/Component"
        },
        "shipping": {
          "$ref": "#/definitions/Component"
        },
        "kafka": {
          "$ref": "#/definitions/Component"
        },
        "llm": {
          "$ref": "#/definitions/Component"
        },
        "postgresql": {
          "$ref": "#/definitions/Component"
        },
        "valkey-cart": {
          "$ref": "#/definitions/Component"
        },
        "opensearch": {
          "$ref": "#/definitions/Component"
        }
      },
      "title": "Components"
    },
    "Component": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "serviceAccount": {
          "description": "SEC-03: per-component ServiceAccount for least-privilege identity. When omitted, the chart creates an identity named after the component.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "create": {
              "type": "boolean"
            },
            "annotations": {
              "type": "object"
            },
            "name": {
              "type": "string"
            },
            "automountServiceAccountToken": {
              "type": "boolean",
              "const": false
            }
          },
          "required": [
            "create"
          ]
        },
        "useDefault": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "env": {
              "type": "boolean",
              "additionalProperties": false
            }
          },
          "required": [
            "env"
          ]
        },
        "imageOverride": {
          "$ref": "#/definitions/Image"
        },
        "replicas": {
          "type": "integer"
        },
        "optionalDependencyTimeoutMs": {
          "type": "integer",
          "minimum": 1
        },
        "stateful": {
          "type": "boolean"
        },
        "terminationGracePeriodSeconds": {
          "type": "integer"
        },
        "preStopSleepSeconds": {
          "type": "integer",
          "minimum": 1,
          "description": "Native Kubernetes preStop sleep used to drain endpoints before SIGTERM without requiring a shell in the image."
        },
        "revisionHistoryLimit": {
          "type": "integer"
        },
        "service": {
          "$ref": "#/definitions/Service"
        },
        "ports": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Port"
          }
        },
        "env": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Env"
          }
        },
        "envOverrides": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Env"
          }
        },
        "command": {
          "type": "array",
          "items": {}
        },
        "additionalVolumeMounts": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "mountedConfigMaps": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/MountedConfigMap"
          }
        },
        "mountedEmptyDirs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/MountedEmptyDirs"
          }
        },
        "modelDelivery": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "awsRegion": {
              "type": "string"
            },
            "fetcherImage": {
              "type": "string"
            },
            "extractorImage": {
              "type": "string"
            },
            "s3Uri": {
              "type": "string",
              "pattern": "^s3://"
            },
            "mountPath": {
              "type": "string"
            },
            "cacheSizeLimit": {
              "type": "string"
            },
            "resources": {
              "$ref": "#/definitions/ContainerResources"
            }
          }
        },
        "livenessProbe": {
          "$ref": "#/definitions/LivenessProbe"
        },
        "readinessProbe": {
          "$ref": "#/definitions/ReadinessProbe"
        },
        "startupProbe": {
          "$ref": "#/definitions/StartupProbe"
        },
        "rollout": {
          "$ref": "#/definitions/Rollout"
        },
        "schedulingRules": {
          "$ref": "#/definitions/SchedulingRules"
        },
        "podLabels": {
          "type": "object"
        },
        "podAnnotations": {
          "type": "object"
        },
        "resources": {
          "$ref": "#/definitions/ContainerResources"
        },
        "securityContext": {
          "$ref": "#/definitions/SecurityContext"
        },
        "podSecurityContext": {
          "$ref": "#/definitions/PodSecurityContext"
        },
        "ingress": {
          "$ref": "#/definitions/Ingress"
        },
        "publicAlb": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "ingressClassName": {
              "type": "string"
            },
            "scheme": {
              "type": "string",
              "description": "ALB scheme: internal (default; CloudFront VPC origin target) or internet-facing (legacy/break-glass)."
            },
            "targetType": {
              "type": "string"
            },
            "listenPorts": {
              "type": "string"
            },
            "certificateArn": {
              "type": "string",
              "description": "Optional ACM certificate ARN for HTTPS on the internal ALB."
            },
            "host": {
              "type": "string"
            },
            "blockSensitivePaths": {
              "type": "boolean",
              "description": "Emergency only: when true, ALB returns HTTP 403 for blockedPrefixes. Prefer CloudFront Function path blocking; default false with internal ALB."
            },
            "blockedPrefixes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "initContainers": {
          "type": "array"
        },
        "sidecarContainers": {
          "type": "array"
        },
        "volumeClaimTemplates": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "additionalVolumes": {
          "type": "array"
        },
        "pdb": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "minAvailable": {
              "type": [
                "integer",
                "string"
              ]
            },
            "maxUnavailable": {
              "type": [
                "integer",
                "string"
              ]
            }
          }
        },
        "autoscaling": {
          "$ref": "#/definitions/Autoscaling"
        },
        "sidecarImageDigests": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "description": "Map of sidecar container name to image digest. Used for flagd-ui without replacing sidecarContainers."
        }
      },
      "required": [
        "enabled",
        "useDefault"
      ],
      "title": "Service"
    },
    "Env": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "valueFrom": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "configMapKeyRef": {
              "$ref": "#/definitions/ConfigMapKeyRef"
            },
            "fieldRef": {
              "$ref": "#/definitions/FieldRef"
            },
            "resourceFieldRef": {
              "$ref": "#/definitions/ResourceFieldRef"
            },
            "secretKeyRef": {
              "$ref": "#/definitions/SecretKeyRef"
            }
          }
        }
      },
      "required": [
        "name"
      ],
      "title": "Env"
    },
    "Default": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "env": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Env"
          }
        },
        "envOverrides": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Env"
          }
        },
        "replicas": {
          "type": "integer"
        },
        "revisionHistoryLimit": {
          "type": "integer"
        },
        "terminationGracePeriodSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "preStopSleepSeconds": {
          "type": "integer",
          "minimum": 1,
          "description": "Default native Kubernetes preStop sleep for component containers."
        },
        "image": {
          "$ref": "#/definitions/Image"
        },
        "schedulingRules": {
          "$ref": "#/definitions/SchedulingRules"
        },
        "securityContext": {
          "$ref": "#/definitions/SecurityContext"
        },
        "podSecurityContext": {
          "$ref": "#/definitions/PodSecurityContext"
        },
        "initContainerSecurityContext": {
          "$ref": "#/definitions/SecurityContext"
        },
        "initContainerResources": {
          "$ref": "#/definitions/ContainerResources"
        },
        "rollout": {
          "$ref": "#/definitions/Rollout"
        },
        "storageClassName": {
          "type": "string"
        }
      },
      "required": [
        "image",
        "schedulingRules",
        "securityContext"
      ],
      "title": "Default"
    },
    "ConfigMapKeyRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "optional": {
          "type": "boolean"
        }
      },
      "required": [
        "key"
      ],
      "title": "ConfigMapKeyRef"
    },
    "FieldRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fieldPath": {
