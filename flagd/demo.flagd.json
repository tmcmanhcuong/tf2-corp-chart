{
  "$schema": "https://flagd.dev/schema/v0/flags.json",
  "flags": {
    "local-llmInaccurateResponse": {
      "defaultVariant": "off",
      "description": "(team local) LLM returns an inaccurate product summary for product ID L9ECAV7KIM",
      "state": "ENABLED",
      "variants": {
        "off": false,
        "on": true
      }
    },
    "local-llmRateLimitError": {
      "defaultVariant": "off",
      "description": "(team local) LLM intermittently returns a rate limit error",
      "state": "ENABLED",
      "variants": {
        "off": false,
        "on": true
      }
    },
    "local-productCatalogFailure": {
      "description": "(team local) Fail product catalog service on a specific product",
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "off"
    },
    "local-recommendationCacheFailure": {
      "description": "(team local) Fail recommendation service cache",
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "off"
    },
    "local-adManualGc": {
      "description": "(team local) Triggers full manual garbage collections in the ad service",
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "off"
    },
    "local-adHighCpu": {
      "description": "(team local) Triggers high cpu load in the ad service",
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "off"
    },
    "local-adFailure": {
      "description": "(team local) Fail ad service",
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "off"
    },
    "local-kafkaQueueProblems": {
      "description": "(team local) Overloads Kafka queue while simultaneously introducing a consumer side delay leading to a lag spike",
      "state": "ENABLED",
      "variants": {
        "on": 100,
        "off": 0
      },
      "defaultVariant": "off"
    },
    "local-cartFailure": {
      "description": "(team local) Fail cart service",
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "off"
    },
    "local-paymentFailure": {
      "description": "(team local) Fail payment service charge requests n%",
      "state": "ENABLED",
      "variants": {
        "100%": 1,
        "90%": 0.95,
        "75%": 0.75,
        "50%": 0.5,
        "25%": 0.25,
        "10%": 0.1,
        "off": 0
      },
      "defaultVariant": "off"
    },
    "local-paymentUnreachable": {
      "description": "(team local) Payment service is unavailable",
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "off"
    },
    "local-loadGeneratorFloodHomepage": {
      "description": "(team local) Flood the frontend with a large amount of requests.",
      "state": "ENABLED",
      "variants": {
        "on": 100,
        "off": 0
      },
      "defaultVariant": "off"
    },
    "local-imageSlowLoad": {
      "description": "(team local) slow loading images in the frontend",
      "state": "ENABLED",
      "variants": {
        "10sec": 10000,
        "5sec": 5000,
        "off": 0
      },
      "defaultVariant": "off"
    },
    "local-failedReadinessProbe": {
      "description": "(team local) readiness probe failure for cart service",
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "off"
    },
    "local-emailMemoryLeak": {
      "description": "(team local) Memory leak in the email service.",
      "state": "ENABLED",
      "variants": {
        "off": 0,
        "1x": 1,
        "10x": 10,
        "100x": 100,
        "1000x": 1000,
        "10000x": 10000
      },
      "defaultVariant": "off"
    }
  }
}
