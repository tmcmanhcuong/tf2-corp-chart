      "id": 1,
      "panels": [],
      "title": "Service Status & Restarts (Active Pods)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          },
          "editorMode": "code",
          "expr": "sum(kube_pod_container_status_restarts_total{namespace=~\"$namespace\", container=~\"$service\"} * on(pod) group_left() kube_pod_info)",
          "instant": true,
          "legendFormat": "Restarts",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Total Restarts",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsSystem"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 5,
        "w": 20,
        "x": 4,
        "y": 1
      },
      "id": 3,
      "options": {
        "footer": {
          "fields": [],
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          },
          "editorMode": "code",
          "expr": "kube_pod_container_status_waiting_reason{namespace=~\"$namespace\", container=~\"$service\"} * on(pod) group_left() (kube_pod_start_time{namespace=~\"$namespace\"} * on(pod) group_left() kube_pod_info) > 0",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Waiting Status (CrashLoopBackOff etc.)",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "keepLabels": false,
            "mode": "columns"
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "app_kubernetes_io_component": true,
              "app_kubernetes_io_instance": true,
              "app_kubernetes_io_managed_by": true,
              "app_kubernetes_io_name": true,
              "app_kubernetes_io_part_of": true,
              "app_kubernetes_io_version": true,
              "container": true,
              "helm_sh_chart": true,
              "instance": true,
              "job": true,
              "namespace": true,
              "node": true,
              "service": true,
              "uid": true
            },
            "indexByName": {
              "pod": 0,
              "reason": 1,
              "Value": 2
            },
            "renameByName": {
              "pod": "Pod",
              "reason": "Waiting Status",
              "Value": "Start Time"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsSystem"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 4,
      "options": {
        "footer": {
          "fields": [],
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          },
          "editorMode": "code",
          "expr": "kube_pod_container_status_last_terminated_reason{namespace=~\"$namespace\", container=~\"$service\"} * on(pod, container) group_left() (kube_pod_container_status_last_terminated_timestamp{namespace=~\"$namespace\", container=~\"$service\"} * on(pod) group_left() kube_pod_info) > 0",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Last Terminated Reason",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "keepLabels": false,
            "mode": "columns"
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "app_kubernetes_io_component": true,
              "app_kubernetes_io_instance": true,
              "app_kubernetes_io_managed_by": true,
              "app_kubernetes_io_name": true,
              "app_kubernetes_io_part_of": true,
              "app_kubernetes_io_version": true,
              "container": true,
              "helm_sh_chart": true,
              "instance": true,
              "job": true,
              "namespace": true,
              "node": true,
              "service": true,
              "uid": true
            },
            "indexByName": {
              "pod": 0,
              "reason": 1,
              "Value": 2
            },
            "renameByName": {
              "pod": "Pod",
              "reason": "Termination Reason",
              "Value": "Termination Time"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "id": 10,
      "panels": [],
      "title": "Pod Resource Metrics (Usage vs Configured Limit)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "opacity"
          },
          "unit": "cores"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "/.*Limit/"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "solid",
                  "dash": [
                    5,
                    5
                  ]
                }
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "id": 11,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          },
          "editorMode": "code",
          "expr": "sum(rate(k8s_pod_cpu_time_seconds_total{}[$__rate_interval])) by (k8s_pod_name) * on(k8s_pod_name) group_left() (max(target_info{service_name=\"$service\", service_namespace=\"techx-corp-prod\"}) by (k8s_pod_name))",
          "legendFormat": "{{k8s_pod_name}} CPU Usage",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          },
          "editorMode": "code",
          "expr": "sum(kube_pod_container_resource_limits{resource=\"cpu\", namespace=~\"$namespace\", container=~\"$service\"}) by (pod)",
          "legendFormat": "{{pod}} CPU Limit",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "CPU Usage vs Limit",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "opacity"
          },
          "unit": "bytes"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "/.*Limit/"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "solid",
                  "dash": [
                    5,
                    5
                  ]
                }
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "id": 12,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          },
          "editorMode": "code",
          "expr": "sum(k8s_pod_memory_working_set_bytes{}) by (k8s_pod_name) * on(k8s_pod_name) group_left() (max(target_info{service_name=\"$service\", service_namespace=\"techx-corp-prod\"}) by (k8s_pod_name))",
          "legendFormat": "{{k8s_pod_name}} Memory Usage",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          },
          "editorMode": "code",
          "expr": "sum(kube_pod_container_resource_limits{resource=\"memory\", namespace=~\"$namespace\", container=~\"$service\"}) by (pod)",
          "legendFormat": "{{pod}} Memory Limit",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Memory Usage vs Limit",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
