          {
            "matcher": {
              "id": "byName",
              "options": "Logger"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 180
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "id": 7,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": []
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "alias": "",
          "bucketAggs": [],
          "datasource": {
            "type": "grafana-opensearch-datasource",
            "uid": "${opensearch_datasource}"
          },
          "format": "table",
          "hide": false,
          "metrics": [
            {
              "id": "1",
              "settings": {
                "order": "desc",
                "size": "100",
                "useTimeRange": true
              },
              "type": "raw_data"
            }
          ],
          "query": "search source=otel-logs-* | where resource.k8s.namespace.name=\"$namespace\" and resource.service.name=\"$service\" | sort - observedTimestamp | head 100",
          "queryType": "PPL",
          "refId": "A",
          "timeField": "observedTimestamp"
        }
      ],
      "title": "Application & Container Log Records (Last 100 entries)",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "@timestamp": true
            },
            "includeByName": {},
            "indexByName": {
              "observedTimestamp": 0,
              "severity.text": 1,
              "body": 2,
              "instrumentationScope.name": 3
            },
            "renameByName": {
              "body": "Message",
              "instrumentationScope.name": "Logger",
              "observedTimestamp": "Time",
              "severity.text": "Severity"
            }
          }
        }
      ],
      "type": "table"
    }
  ],
