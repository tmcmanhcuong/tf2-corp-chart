          "datasource": {
            "type": "grafana-athena-datasource",
            "uid": "finops-athena-cur"
          },
          "format": 0,
          "rawSQL": "WITH daily AS (\n  SELECT date_trunc('day', line_item_usage_start_date) AS day,\n         SUM(CAST(line_item_unblended_cost AS double)) AS daily_cost\n  FROM \"${cur_database}\".\"${cur_table}\"\n  WHERE line_item_usage_start_date >= date_trunc('month', current_date)\n    AND line_item_usage_start_date < current_date + interval '1' day\n  GROUP BY 1\n)\nSELECT day AS time,\n       SUM(daily_cost) OVER (ORDER BY day ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS cumulative_cost\nFROM daily\nORDER BY 1",
          "refId": "A",
          "table": "${cur_table}"
        }
      ],
      "title": "Cumulative Monthly Spend",
      "type": "timeseries"
