      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "webstore-metrics"
          },
          "editorMode": "code",
          "expr": "((sum(node_namespace_pod_container:container_cpu_usage_seconds_total:sum_irate{container=\"$service\", namespace=\"techx-corp-prod\"}) or vector(0)) / (sum(kube_pod_container_resource_requests{resource=\"cpu\", container=\"$service\", namespace=\"techx-corp-prod\"}) or vector(1))) * 100",
          "legendFormat": "CPU Request Utilization",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "CPU Request Utilization %",
      "type": "stat"
    },
