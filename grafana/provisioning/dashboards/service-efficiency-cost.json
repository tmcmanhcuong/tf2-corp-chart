        {
          "datasource": {
            "type": "prometheus",
            "uid": "webstore-metrics"
          },
          "editorMode": "code",
          "expr": "((sum(rate(container_cpu_usage_seconds_total{container=\"$service\", namespace=\"techx-corp-prod\"}[2m])) or vector(0)) / (sum(kube_pod_container_resource_requests{resource=\"cpu\", container=\"$service\", namespace=\"techx-corp-prod\"}) or vector(1))) * 100",
          "legendFormat": "CPU Request Utilization %",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "webstore-metrics"
          },
          "editorMode": "code",
          "expr": "((sum(container_memory_working_set_bytes{container=\"$service\", namespace=\"techx-corp-prod\"}) or vector(0)) / (sum(kube_pod_container_resource_requests{resource=\"memory\", container=\"$service\", namespace=\"techx-corp-prod\"}) or vector(1))) * 100",
          "legendFormat": "Memory Request Utilization %",
          "range": true,
          "refId": "C"
        }
      ],
