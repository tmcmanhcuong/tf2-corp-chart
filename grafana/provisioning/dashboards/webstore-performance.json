        {
          "datasource": {
            "type": "prometheus",
            "uid": "webstore-metrics"
          },
          "editorMode": "code",
          "expr": "100 * (1 - (sum(rate(traces_span_metrics_duration_milliseconds_count{service_name=\"frontend\", span_name=~\"render route.*|GET /products/.*\", status_code=\"STATUS_CODE_ERROR\"}[5m])) or vector(0)) / sum(rate(traces_span_metrics_duration_milliseconds_count{service_name=\"frontend\", span_name=~\"render route.*|GET /products/.*\"}[5m])))",
          "instant": false,
          "range": true,
          "refId": "A"
