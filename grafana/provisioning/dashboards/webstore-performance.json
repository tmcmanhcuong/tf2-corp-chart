          "editorMode": "code",
          "expr": "quantile_over_time(0.95, sum(container_memory_working_set_bytes{namespace=\"techx-corp-prod\", container!=\"\"}) by (container)[$__range:1m])",
          "instant": true,
          "legendFormat": "P95 Memory",
          "range": false,
          "refId": "E"
