          "editorMode": "code",
          "expr": "100 * ((sum by (pod) (rate(container_network_receive_bytes_total{namespace=\"techx-corp-prod\", pod=~\"$service-.*\"}[$__rate_interval])) * on (pod) group_left() (kube_pod_status_phase{namespace=\"techx-corp-prod\", phase=\"Running\"} == 1)) / scalar(sum(rate(container_network_receive_bytes_total{namespace=\"techx-corp-prod\", pod=~\"$service-.*\"}[$__rate_interval]) * on (pod) group_left() (kube_pod_status_phase{namespace=\"techx-corp-prod\", phase=\"Running\"} == 1))))",
          "legendFormat": "{{pod}}",
