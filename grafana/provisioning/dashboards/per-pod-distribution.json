      "title": "Request rate theo pod ($service)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "webstore-metrics"
          },
          "editorMode": "code",
          "expr": "(sum by (pod) (rate(container_network_receive_bytes_total{namespace=\"techx-corp-prod\", pod=~\"$service-.*\"}[$__rate_interval])) / 1024) * on (pod) group_left() (kube_pod_status_phase{namespace=\"techx-corp-prod\", phase=\"Running\"} == 1)",
          "legendFormat": "{{pod}} (KB/s)",
          "refId": "A"
        }
      ]
    },
